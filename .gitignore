# Dependencies
node_modules/

# Build
dist/
target/

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Environment
.env
.env.local

# Logs
*.log

# Tauri
src-tauri/target/

# Claude Code project-level MCP config — contains user-specific paths
# and API keys (e.g. SEMANTIC_SCHOLAR_API_KEY); do not commit.
.mcp.json

# Playwright MCP cache (browser-state snapshots / console logs from
# automated debugging sessions). Machine-local, never useful checked in.
.playwright-mcp/

# Claude Code runtime lockfile (sessionId + pid; rewritten each launch).
.claude/scheduled_tasks.lock

# Internal development scratch — design specs, tech plans, bug audits,
# SubAgent prompts, release plans. Useful only inside the local working
# tree; not for public consumption.
.dev/
